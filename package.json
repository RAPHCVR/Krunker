{
  "name": "krunker-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @krunker-arena/server --filter @krunker-arena/client dev",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm --filter @krunker-arena/shared build && corepack pnpm --filter @krunker-arena/client --filter @krunker-arena/server typecheck",
    "lint": "corepack pnpm -r lint",
    "test": "corepack pnpm -r test",
    "smoke:browser": "node scripts/browser-smoke.mjs",
    "smoke:browser:respawn": "node -e \"process.env.SMOKE_RESPAWN='1'; import('./scripts/browser-smoke.mjs')\"",
    "smoke:latency": "corepack pnpm --filter @krunker-arena/shared build && node scripts/latency-playtest.mjs",
    "clean": "corepack pnpm -r clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "eslint": "^9.38.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "@colyseus/core>nanoid": "^3.3.11"
    },
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild",
      "msgpackr-extract"
    ],
    "patchedDependencies": {
      "@colyseus/core@0.16.24": "patches/@colyseus__core@0.16.24.patch"
    }
  }
}
